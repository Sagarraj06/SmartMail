# Smartmail Environment Variables

# Gmail API Credentials
# These will be used if credentials.json is not available
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Voice Settings
VOICE_RATE=150  # Speed of speech (words per minute)
VOICE_VOLUME=1.0  # Volume (0.0 to 1.0)
RECORDING_DURATION=5  # Duration of voice recording in seconds

# Model Settings
WHISPER_MODEL=base  # Options: tiny, base, small, medium, large
WHISPER_DEVICE=cpu  # Options: cpu, cuda
WHISPER_COMPUTE_TYPE=int8  # Options: int8, float16, float32

# Logging
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL 